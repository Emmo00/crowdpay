# Stellar network
NETWORK=testnet

# Database connection
DATABASE_URL=postgres://user:password@localhost:5432/crowdpay_dev
DATABASE_POOL_SIZE=10

# Stellar asset configuration
USDC_CONTRACT=CBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Optional: add extra supported assets as JSON {"CODE":"ISSUER_ADDRESS"}
# STELLAR_EXTRA_ASSETS=

# ── Soroban / Smart contracts ─────────────────────────
# Set SOROBAN_ENABLED=true to deploy real contract instances on campaign creation
# SOROBAN_ENABLED=false
# WASM hashes from contracts/soroban deploy output (issue #245)
# ESCROW_WASM_HASH=
# MILESTONES_WASM_HASH=
# USDC token contract on Soroban (testnet example may differ)
# USDC_CONTRACT_ADDRESS=
# PLATFORM_FEE_BPS=0

# The Stellar secret key for the platform co-signer account
# Generate a new keypair: https://laboratory.stellar.org/#account-creator
PLATFORM_SECRET_KEY=replace-with-platform-stellar-secret

# Freighter API configuration
FREIGHTER_API_KEY=replace-with-freighter-api-key
FREIGHTER_API_SECRET=replace-with-freighter-api-secret

# Email service configuration
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@crowdpay.app
SENDGRID_FROM_NAME=CrowdPay

# KYC Provider configuration
KYC_PROVIDER=sumsub
SUMSUB_API_KEY=replace-with-sumsub-api-key
SUMSUB_SECRET_KEY=replace-with-sumsub-secret-key

# JWT Configuration
JWT_SECRET=replace-with-jwt-secret
JWT_EXPIRY_DAYS=30

# Application settings
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
LOG_LEVEL=info

# Feature flags
ENABLE_MOCK_STELLAR=false
ENABLE_TEST_MODE=false
